# ═══════════════════════════════════════════════════════════════════════════
# LNCP META v5.0 ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env.lncp and fill in your values
# Required variables are marked with [REQUIRED]
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# PERSISTENCE
# ─────────────────────────────────────────────────────────────────────────────

# Directory for all persistent data (databases, config files)
# Default: /var/lib/lncp (production) or ./data (development)
LNCP_DATA_DIR=/var/lib/lncp

# ─────────────────────────────────────────────────────────────────────────────
# STRIPE INTEGRATION [REQUIRED FOR PRODUCTION]
# ─────────────────────────────────────────────────────────────────────────────

# Stripe API key (reuses app's STRIPE_SECRET_KEY if not set)
# Use sk_test_... for development, sk_live_... for production
STRIPE_API_KEY=sk_test_...

# Stripe webhook signing secret for Meta-specific webhooks
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE SEARCH CONSOLE [REQUIRED FOR PRODUCTION]
# ─────────────────────────────────────────────────────────────────────────────

# Path to Google service account credentials JSON file
# Get from: https://console.cloud.google.com/apis/credentials
GSC_CREDENTIALS_PATH=/etc/lncp/gsc-credentials.json

# Your verified site URL in Search Console
GSC_SITE_URL=https://quirrely.com

# ─────────────────────────────────────────────────────────────────────────────
# ALERTING
# ─────────────────────────────────────────────────────────────────────────────

# Slack incoming webhook URL for alerts
LNCP_SLACK_WEBHOOK=https://hooks.slack.com/services/T.../B.../...

# Email address for critical alerts
LNCP_ALERT_EMAIL=admin@your-domain.com

# SMTP configuration for email alerts
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL SETTINGS
# ─────────────────────────────────────────────────────────────────────────────

# Environment: development, staging, production
LNCP_ENV=production

# Enable simulation mode (use fake data instead of real APIs)
LNCP_SIMULATION_MODE=false

# Super Admin API key
LNCP_ADMIN_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────────────────────────────────────────

# Enable ML model predictions
LNCP_ENABLE_ML=true

# Enable auto-apply (false = suggest only mode)
LNCP_ENABLE_AUTO_APPLY=true

# Maximum auto-apply actions per cycle
LNCP_MAX_AUTO_PER_CYCLE=10
