@router.post("/login", response_model=TokenResponse)
async def login(request: LoginRequest):
    import subprocess, hashlib, secrets, bcrypt
    email=request.email.lower().strip()
    pw_hash=bcrypt.hashpw(request.password.encode(),bcrypt.gensalt()).decode() if request.password else ""
    r=subprocess.run(["sudo","-u","postgres","psql","-d","quirrely_prod","-t","-c",
        f"SELECT id,display_name FROM users WHERE email='{email}';"],
        capture_output=True,text=True,timeout=10)
    row=r.stdout.strip()
    if not row:
        raise HTTPException(status_code=401,detail="Invalid email or password")
    parts=[p.strip() for p in row.split("|")]
    user_id=parts[0]; dn=parts[1] if len(parts)>1 else ""
    if user_id not in _users:
        _users[user_id]={"id":user_id,"email":email,"password_hash":pw_hash,"email_verified":False,"display_name":dn}
    elif _users[user_id].get("password_hash") and not bcrypt.checkpw(request.password.encode(), _users[user_id]["password_hash"].encode()):
        raise HTTPException(status_code=401,detail="Invalid email or password")
    access_token=secrets.token_urlsafe(32)
    refresh_token=secrets.token_urlsafe(32)
    expires_at=datetime.utcnow()+timedelta(hours=SESSION_CONFIG["session_lifetime_hours"])
    _sessions[access_token]={"user_id":user_id,"expires_at":expires_at,"refresh_token":refresh_token}
    subprocess.run(["sudo","-u","postgres","psql","-d","quirrely_prod","-c",
        f"UPDATE users SET last_login_at=now() WHERE id='{user_id}';"],
        capture_output=True,text=True,timeout=10)
    return TokenResponse(access_token=access_token,refresh_token=refresh_token,token_type="bearer",expires_in=SESSION_CONFIG["session_lifetime_hours"]*3600,user={"id":user_id,"email":email,"display_name":dn})

