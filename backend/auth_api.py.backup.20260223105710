@router.post("/account/delete")
async def delete_account(
    request: DeleteAccountRequest,
    user: Dict = Depends(require_auth),
):
    """Delete account (soft or hard)."""
    user_id = user["id"]
    
    if request.hard_delete:
        # Hard delete requires confirmation phrase
        if request.confirmation != ACCOUNT_DELETION_CONFIG["hard_delete"]["confirmation_phrase"]:
            raise HTTPException(
                status_code=400,
                detail=f"Type '{ACCOUNT_DELETION_CONFIG['hard_delete']['confirmation_phrase']}' to confirm"
            )
        
        # Hard delete
        _deleted_accounts[user_id] = {
            "deleted_at": datetime.utcnow(),
            "type": "hard",
            "email": user.get("email"),  # Keep for audit
        }
        
        del _users[user_id]
        
        # Remove all sessions
        to_remove = [t for t, s in _sessions.items() if s.get("user_id") == user_id]
        for token in to_remove:
            del _sessions[token]
        
        return {"message": "Account permanently deleted"}
    
    else:
        # Soft delete
        _users[user_id]["deleted_at"] = datetime.utcnow()
        _users[user_id]["status"] = "deleted"
        _users[user_id]["recovery_until"] = datetime.utcnow() + timedelta(
            days=ACCOUNT_DELETION_CONFIG["soft_delete"]["recovery_days"]
        )
        
        # Remove all sessions
        to_remove = [t for t, s in _sessions.items() if s.get("user_id") == user_id]
        for token in to_remove:
            del _sessions[token]
        
        return {
            "message": "Account deactivated",
            "recovery_until": _users[user_id]["recovery_until"],
        }


@router.post("/account/recover")
async def recover_account(email: EmailStr, password: str):
    """Recover soft-deleted account."""
    email = email.lower().strip()
    
    for user_id, user in _users.items():
        if user.get("email") == email and user.get("status") == "deleted":
            # Check if still recoverable
            if datetime.utcnow() > user.get("recovery_until", datetime.min):
                raise HTTPException(status_code=400, detail="Recovery period expired")
            
            # Verify password
            if user.get("password_hash") and not bcrypt.checkpw(password.encode(), user["password_hash"].encode()):
                raise HTTPException(status_code=401, detail="Invalid password")
            
            # Recover account
            user["status"] = "active"
            user.pop("deleted_at", None)
            user.pop("recovery_until", None)
            user["updated_at"] = datetime.utcnow()
            
            return {"message": "Account recovered successfully"}
    
    raise HTTPException(status_code=404, detail="Account not found")


