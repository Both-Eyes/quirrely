@router.post("/refresh")
async def refresh_token(refresh_token: str):
    """Refresh access token."""
    # Find session with this refresh token
    for access_token, session in _sessions.items():
        if session.get("refresh_token") == refresh_token:
            # Create new tokens
            import secrets
            new_access_token = secrets.token_urlsafe(32)
            new_refresh_token = secrets.token_urlsafe(32)
            
            expires_at = datetime.utcnow() + timedelta(hours=SESSION_CONFIG["session_lifetime_hours"])
            
            # Remove old session
            del _sessions[access_token]
            
            # Create new session
            _sessions[new_access_token] = {
                "user_id": session["user_id"],
                "expires_at": expires_at,
                "refresh_token": new_refresh_token,
            }
            
            user = _users.get(session["user_id"], {})
            
            return TokenResponse(
                access_token=new_access_token,
                refresh_token=new_refresh_token,
                expires_in=SESSION_CONFIG["session_lifetime_hours"] * 3600,
                user={
                    "id": user.get("id"),
                    "email": user.get("email"),
                    "email_verified": user.get("email_verified"),
                    "display_name": user.get("display_name"),
                },
            )
    
    raise HTTPException(status_code=401, detail="Invalid refresh token")


@router.post("/logout")
async def logout(user: Dict = Depends(require_auth), authorization: str = Header(None)):
    """Logout current session."""
    token = authorization[7:] if authorization else None
    
    if token and token in _sessions:
        del _sessions[token]
    
    return {"message": "Logged out successfully"}


@router.post("/logout/all")
async def logout_all_sessions(user: Dict = Depends(require_auth)):
    """Logout all sessions for user."""
    user_id = user["id"]
    
    # Remove all sessions for this user
    to_remove = [
        token for token, session in _sessions.items()
        if session.get("user_id") == user_id
    ]
    
    for token in to_remove:
        del _sessions[token]
    
    return {"message": f"Logged out of {len(to_remove)} sessions"}


