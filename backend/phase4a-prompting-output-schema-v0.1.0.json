{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phase4a-prompting-output-schema-v0.1.0",
  "title": "Phase-4a Prompting Output Schema",
  "description": "Schema for Phase-4a Prompting Mode. Consumes Phase-3 syntheses and emits prompt sets (NOTICE/REFLECT/REWRITE/COMPARE).",
  "type": "object",
  "required": [
    "phase4a_version",
    "source_contract_version",
    "source_phase2_version",
    "source_phase3_version",
    "prompt_sets"
  ],
  "additionalProperties": false,
  "properties": {
    "phase4a_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "source_contract_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "source_phase2_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "source_phase3_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "prompt_sets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "prompt_set_id",
          "synthesis_id",
          "related_outputs",
          "semiotic_lens",
          "prompts"
        ],
        "additionalProperties": false,
        "properties": {
          "prompt_set_id": {
            "type": "string",
            "pattern": "^PS_\\d{2,3}$",
            "description": "Stable identifier for this prompt set (e.g., PS_01)."
          },
          "synthesis_id": {
            "type": "string",
            "pattern": "^SYN_\\d{2,3}$",
            "description": "Phase-3 synthesis this set is derived from."
          },
          "related_outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^output_\\d{2}$"
            }
          },
          "semiotic_lens": {
            "type": "string",
            "minLength": 1
          },
          "prompts": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": {
              "type": "object",
              "required": [
                "prompt_type",
                "prompt_text"
              ],
              "additionalProperties": false,
              "properties": {
                "prompt_type": {
                  "type": "string",
                  "enum": [
                    "NOTICE",
                    "REFLECT",
                    "REWRITE",
                    "COMPARE"
                  ]
                },
                "prompt_text": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  }
}