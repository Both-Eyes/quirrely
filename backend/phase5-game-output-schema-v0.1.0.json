{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phase5-game-output-schema-v0.1.0",
  "title": "Phase-5 Gamification Output Schema",
  "description": "Schema for Phase-5 sample-building game state output. Downstream phases (1\u20134) must not execute until gate completion (3/3 valid groups).",
  "type": "object",
  "required": [
    "phase5_version",
    "state",
    "gate",
    "progress",
    "prompting",
    "coverage",
    "safety",
    "routing"
  ],
  "additionalProperties": false,
  "properties": {
    "phase5_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "state": {
      "type": "string",
      "enum": [
        "ENTRY",
        "PLAY",
        "COVERAGE_CHECK",
        "LAB_CHALLENGE",
        "COMPLETION",
        "PIPELINE_EXECUTION",
        "ABORTED"
      ]
    },
    "gate": {
      "type": "object",
      "required": [
        "required_valid_groups",
        "valid_groups_count",
        "is_complete"
      ],
      "additionalProperties": false,
      "properties": {
        "required_valid_groups": {
          "type": "integer",
          "const": 3
        },
        "valid_groups_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "is_complete": {
          "type": "boolean"
        }
      }
    },
    "progress": {
      "type": "object",
      "required": [
        "groups",
        "failure_count"
      ],
      "additionalProperties": false,
      "properties": {
        "groups": {
          "type": "array",
          "minItems": 0,
          "maxItems": 3,
          "items": {
            "type": "object",
            "required": [
              "group_id",
              "sentences",
              "is_valid"
            ],
            "additionalProperties": false,
            "properties": {
              "group_id": {
                "type": "string",
                "pattern": "^G[1-3]$"
              },
              "sentences": {
                "type": "array",
                "minItems": 2,
                "maxItems": 3,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "is_valid": {
                "type": "boolean"
              },
              "validation_message": {
                "type": "string",
                "description": "Minimal gate feedback (e.g., 'Not valid, try again.'). Optional; may be omitted when gate is not complete."
              }
            }
          }
        },
        "failure_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Total consecutive failures in the current play cycle (used for soft-cap/auto-skip policies)."
        },
        "soft_cap": {
          "type": "object",
          "required": [
            "is_active",
            "max_failures_before_autoskip"
          ],
          "additionalProperties": false,
          "properties": {
            "is_active": {
              "type": "boolean"
            },
            "max_failures_before_autoskip": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    },
    "prompting": {
      "type": "object",
      "required": [
        "mode",
        "current_prompt",
        "last_submission"
      ],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "STORY",
            "LAB"
          ]
        },
        "current_prompt": {
          "type": "object",
          "required": [
            "prompt_id",
            "prompt_type",
            "text"
          ],
          "additionalProperties": false,
          "properties": {
            "prompt_id": {
              "type": "string",
              "minLength": 1
            },
            "prompt_type": {
              "type": "string",
              "enum": [
                "NOTICE",
                "REFLECT",
                "REWRITE",
                "COMPARE"
              ]
            },
            "text": {
              "type": "string",
              "minLength": 1
            },
            "selection_meta": {
              "type": "object",
              "description": "Optional deterministic selection metadata (e.g., seed, hash, bucket).",
              "additionalProperties": true
            }
          }
        },
        "last_submission": {
          "type": "object",
          "required": [
            "submitted_group",
            "validation"
          ],
          "additionalProperties": false,
          "properties": {
            "submitted_group": {
              "type": "object",
              "required": [
                "sentences"
              ],
              "additionalProperties": false,
              "properties": {
                "sentences": {
                  "type": "array",
                  "minItems": 2,
                  "maxItems": 3,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            "validation": {
              "type": "object",
              "required": [
                "status"
              ],
              "additionalProperties": false,
              "properties": {
                "status": {
                  "type": "string",
                  "enum": [
                    "VALID",
                    "INVALID",
                    "NOT_EVALUATED"
                  ]
                },
                "message": {
                  "type": "string",
                  "description": "Minimal feedback string for strict gate UX (optional)."
                }
              }
            }
          }
        }
      }
    },
    "coverage": {
      "type": "object",
      "required": [
        "coverage_system",
        "is_satisfied",
        "status_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "coverage_system": {
          "type": "string",
          "description": "Identifier for the locked coverage system (e.g., H2).",
          "minLength": 1
        },
        "is_satisfied": {
          "type": "boolean"
        },
        "status_summary": {
          "type": "string",
          "minLength": 1,
          "description": "Short, user-safe status line describing coverage progress."
        },
        "details": {
          "type": "object",
          "description": "Structured coverage bookkeeping (implementation-defined).",
          "additionalProperties": true
        }
      }
    },
    "safety": {
      "type": "object",
      "required": [
        "actor_state",
        "is_deescalating"
      ],
      "additionalProperties": false,
      "properties": {
        "actor_state": {
          "type": "string",
          "enum": [
            "NORMAL",
            "PLAYFUL",
            "HOSTILE",
            "ANGRY"
          ]
        },
        "is_deescalating": {
          "type": "boolean"
        },
        "deescalation_message": {
          "type": "string",
          "description": "Optional user-facing de-escalation copy (only when applicable)."
        },
        "notes": {
          "type": "object",
          "description": "Internal safety notes / flags (non-user-facing).",
          "additionalProperties": true
        }
      }
    },
    "routing": {
      "type": "object",
      "required": [
        "phase1_allowed",
        "phase2_allowed",
        "phase3_allowed",
        "phase4a_allowed",
        "phase4b_allowed",
        "rule_note"
      ],
      "additionalProperties": false,
      "properties": {
        "phase1_allowed": {
          "type": "boolean"
        },
        "phase2_allowed": {
          "type": "boolean"
        },
        "phase3_allowed": {
          "type": "boolean"
        },
        "phase4a_allowed": {
          "type": "boolean"
        },
        "phase4b_allowed": {
          "type": "boolean"
        },
        "rule_note": {
          "type": "string",
          "const": "Phase-4a and Phase-4b are never executed until Phase-5 gate completion (3/3 valid groups)."
        }
      }
    }
  }
}