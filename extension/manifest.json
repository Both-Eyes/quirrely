{
  "manifest_version": 3,
  "name": "Quirrely - Writing Voice Analysis",
  "short_name": "Quirrely",
  "version": "2.0.0",
  "description": "Discover your unique writing voice with LNCP-powered analysis. Now with STRETCH exercises to strengthen your voice!",
  
  "author": "Quirrely",
  "homepage_url": "https://quirrely.com",
  
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  
  "action": {
    "default_popup": "pages/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    },
    "default_title": "Analyze with Quirrely"
  },
  
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus",
    "alarms",
    "notifications"
  ],
  
  "host_permissions": [
    "https://api.quirrely.com/*",
    "https://quirrely.com/*"
  ],
  
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content.js"],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    }
  ],
  
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "styles/*",
        "pages/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  
  "options_page": "pages/options.html",
  
  "commands": {
    "analyze-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+Q",
        "mac": "Command+Shift+Q"
      },
      "description": "Analyze selected text"
    },
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open Quirrely popup"
    },
    "open-stretch": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Open STRETCH exercise"
    }
  },
  
  "minimum_chrome_version": "88"
}
