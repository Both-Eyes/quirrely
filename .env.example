# ═══════════════════════════════════════════════════════
# QUIRRELY v3.1.3 ENVIRONMENT VARIABLES
# Copy to .env and fill in all values before deploying
# DO NOT COMMIT .env TO GIT
# ═══════════════════════════════════════════════════════

# Application
APP_NAME=Quirrely
APP_ENV=production
APP_URL=https://quirrely.com
API_URL=https://api.quirrely.com

# Database (PostgreSQL — NOT MySQL)
DATABASE_URL=postgresql://quirrely:PASSWORD@localhost:5432/quirrely_prod

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=
JWT_SECRET=
SESSION_SECRET=

# Anthropic (if used for future LLM features)
ANTHROPIC_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_AUTHORITY=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=hello@quirrely.com

# Analytics
NEXT_PUBLIC_GA_ID=

# Geo
BLOCKED_COUNTRIES=US

# Feature Flags
ENABLE_STRETCH=true
ENABLE_EXTENSION_SYNC=true
ENABLE_PRO_FEATURES=true
ENABLE_FEATURED_WRITERS=true

# Affiliate
INDIGO_AFFILIATE_ID=
WATERSTONES_AWIN_ID=
BOOKTOPIA_AFFILIATE_ID=
MIGHTYAPE_AFFILIATE_ID=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
