class QuirrellyStat:
    """Main qstats class for collecting and displaying metrics."""
    
    def __init__(self):
        self.console = Console()
        self.db_url = os.getenv('QSTATS_DB_URL', 'postgresql://localhost/quirrely')
        self.redis_url = os.getenv('QSTATS_REDIS_URL', 'redis://localhost:6379')
        self.log_level = os.getenv('QSTATS_LOG_LEVEL', 'INFO')
        
        # Initialize connections
        self.db_conn = None
        self.redis_conn = None
        self.security_logger = None
        self.session_store = None
        
    def connect(self):
        """Establish database and cache connections."""
        try:
            # Database connection
            self.db_conn = psycopg2.connect(self.db_url)
            
            # Redis connection  
            self.redis_conn = redis.from_url(self.redis_url)
            
            # Security components
            self.security_logger = SecurityLogger()
            self.session_store = RedisSessionStore()
            
            return True
        except Exception as e:
            self.console.print(f"[red]Connection failed: {e}[/red]")
            return False
    
    def collect_security_metrics(self) -> SecurityMetrics:
        """Collect security-related metrics."""
        metrics = SecurityMetrics()
        
        try:
            if not self.db_conn:
                return metrics
                
            cursor = self.db_conn.cursor()
            
            # Security events from last 24 hours
            cursor.execute("""
                SELECT 
                    COUNT(*) as total,
                    COUNT(*) FILTER (WHERE severity >= 3) as threats,
                    COUNT(DISTINCT ip_address) FILTER (WHERE blocked = true) as blocked_ips,
                    COUNT(*) FILTER (WHERE event_type = 'auth_failure') as failed_auths,
                    COUNT(*) FILTER (WHERE event_type = 'admin_access') as admin_accesses
                FROM security_events 
                WHERE created_at >= NOW() - INTERVAL '24 hours'
            """)
            
            row = cursor.fetchone()
            if row:
                metrics.total_events = row[0] or 0
                metrics.threat_events = row[1] or 0
                metrics.blocked_ips = row[2] or 0
                metrics.failed_auths = row[3] or 0
                metrics.admin_accesses = row[4] or 0
            
            # WebSocket connections
            if self.redis_conn:
                ws_keys = self.redis_conn.keys("ws:*")
                metrics.websocket_connections = len(ws_keys)
                
                # Active sessions
                session_keys = self.redis_conn.keys("session:*")
                metrics.active_sessions = len(session_keys)
            
            # Calculate security score
            base_score = 100.0
            if metrics.threat_events > 10:
                base_score -= min(30, metrics.threat_events * 2)
            if metrics.failed_auths > 50:
                base_score -= min(20, metrics.failed_auths * 0.3)
            if metrics.blocked_ips > 5:
                base_score -= min(15, metrics.blocked_ips * 2)
            
            metrics.security_score = max(0, base_score)
            
            # Threat types
            cursor.execute("""
                SELECT event_type, COUNT(*) 
                FROM security_events 
                WHERE created_at >= NOW() - INTERVAL '24 hours' AND severity >= 3
                GROUP BY event_type
                ORDER BY COUNT(*) DESC
                LIMIT 5
            """)
            
            metrics.threats_by_type = {row[0]: row[1] for row in cursor.fetchall()}
            
        except Exception as e:
            self.console.print(f"[yellow]Security metrics error: {e}[/yellow]")
            
        return metrics
    
    def collect_user_metrics(self) -> UserMetrics:
        """Collect user and authentication metrics."""
        metrics = UserMetrics()
        
        try:
            if not self.db_conn:
                return metrics
                
            cursor = self.db_conn.cursor()
            
            # User counts
            cursor.execute("""
                SELECT 
                    COUNT(*) as total_users,
                    COUNT(*) FILTER (WHERE created_at::date = CURRENT_DATE) as new_today,
                    COUNT(*) FILTER (WHERE last_login >= NOW() - INTERVAL '1 hour') as active_sessions
                FROM users
            """)
            
            row = cursor.fetchone()
            if row:
                metrics.total_users = row[0] or 0
                metrics.new_signups_today = row[1] or 0
                metrics.active_sessions = row[2] or 0
            
            # Login statistics
            cursor.execute("""
                SELECT 
                    COUNT(*) as total_attempts,
                    COUNT(*) FILTER (WHERE success = true) as successful,
                    COUNT(*) FILTER (WHERE success = false) as failed
                FROM auth_events 
                WHERE created_at::date = CURRENT_DATE
            """)
            
            row = cursor.fetchone()
            if row:
                metrics.login_attempts_today = row[0] or 0
                metrics.successful_logins_today = row[1] or 0
                metrics.failed_logins_today = row[2] or 0
            
            # Tier distribution
            cursor.execute("""
                SELECT tier, COUNT(*) 
                FROM users 
                WHERE tier IS NOT NULL
                GROUP BY tier
                ORDER BY COUNT(*) DESC
            """)
            
            metrics.tier_distribution = {row[0]: row[1] for row in cursor.fetchall()}
            
            # Active countries
            cursor.execute("""
                SELECT COUNT(DISTINCT country) 
                FROM users 
                WHERE last_login >= NOW() - INTERVAL '24 hours'
                AND country IS NOT NULL
            """)
            
            row = cursor.fetchone()
            if row:
                metrics.countries_active = row[0] or 0
                
        except Exception as e:
            self.console.print(f"[yellow]User metrics error: {e}[/yellow]")
            
        return metrics
    
    def collect_feature_metrics(self) -> FeatureMetrics:
        """Collect feature gate usage metrics."""
        metrics = FeatureMetrics()
        
        try:
            if not self.db_conn:
                return metrics
                
            cursor = self.db_conn.cursor()
            
            # Feature access checks
            cursor.execute("""
                SELECT 
                    COUNT(*) as total,
                    COUNT(*) FILTER (WHERE allowed = true) as allowed,
                    COUNT(*) FILTER (WHERE allowed = false) as denied,
                    COUNT(*) FILTER (WHERE reason = 'daily_limit') as limits_hit
                FROM feature_access_log 
                WHERE created_at >= NOW() - INTERVAL '24 hours'
            """)
            
            row = cursor.fetchone()
            if row:
                metrics.total_checks = row[0] or 0
                metrics.allowed_accesses = row[1] or 0
                metrics.denied_accesses = row[2] or 0
                metrics.daily_limits_hit = row[3] or 0
            
            # Feature usage
            cursor.execute("""
                SELECT feature_name, COUNT(*) 
                FROM feature_access_log 
                WHERE created_at >= NOW() - INTERVAL '24 hours' AND allowed = true
                GROUP BY feature_name
                ORDER BY COUNT(*) DESC
                LIMIT 10
            """)
            
            metrics.feature_usage = {row[0]: row[1] for row in cursor.fetchall()}
            
            # Tier upgrade requests
            cursor.execute("""
                SELECT COUNT(*) 
                FROM tier_events 
                WHERE event_type = 'upgrade_request' 
                AND created_at >= NOW() - INTERVAL '24 hours'
            """)
            
            row = cursor.fetchone()
            if row:
                metrics.tier_upgrade_requests = row[0] or 0
                
        except Exception as e:
            self.console.print(f"[yellow]Feature metrics error: {e}[/yellow]")
            
        return metrics
    
    def collect_system_metrics(self) -> SystemMetrics:
        """Collect system performance metrics."""
        metrics = SystemMetrics()
        
        try:
            if self.db_conn:
                cursor = self.db_conn.cursor()
                
                # Database connections
                cursor.execute("SELECT count(*) FROM pg_stat_activity WHERE state = 'active'")
                row = cursor.fetchone()
                if row:
                    metrics.database_connections = row[0] or 0
            
            if self.redis_conn:
                # Redis memory usage
                info = self.redis_conn.info('memory')
                metrics.redis_memory_usage = info.get('used_memory_human', '0B')
                
            # Mock system metrics (in production, use psutil or similar)
            metrics.cpu_usage = 0.0
            metrics.memory_usage = 0.0
            metrics.avg_response_time = 0.0
            metrics.error_rate = 0.0
            metrics.uptime_hours = 0.0
            
        except Exception as e:
            self.console.print(f"[yellow]System metrics error: {e}[/yellow]")
            
        return metrics
    
    def collect_event_metrics(self) -> EventMetrics:
        """Collect meta events and user behavior metrics."""
        metrics = EventMetrics()
        
        try:
            if not self.db_conn:
                return metrics
                
            cursor = self.db_conn.cursor()
            
            # Meta events
            cursor.execute("""
                SELECT 
                    COUNT(*) as total,
                    COUNT(*) FILTER (WHERE created_at::date = CURRENT_DATE) as today,
                    COUNT(DISTINCT session_id) as sessions,
                    COUNT(DISTINCT user_id) as users,
                    COUNT(*) FILTER (WHERE event = 'page_view') as page_views,
                    COUNT(*) FILTER (WHERE event = 'analysis_completed') as analyses
                FROM meta_events 
                WHERE created_at >= NOW() - INTERVAL '7 days'
            """)
            
            row = cursor.fetchone()
            if row:
                metrics.total_events = row[0] or 0
                metrics.events_today = row[1] or 0
                metrics.unique_sessions = row[2] or 0
                metrics.unique_users = row[3] or 0
                metrics.page_views = row[4] or 0
                metrics.analyses_completed = row[5] or 0
            
            # Event types
            cursor.execute("""
                SELECT event, COUNT(*) 
                FROM meta_events 
                WHERE created_at >= NOW() - INTERVAL '24 hours'
                GROUP BY event
                ORDER BY COUNT(*) DESC
                LIMIT 10
            """)
            
            metrics.events_by_type = {row[0]: row[1] for row in cursor.fetchall()}
            
        except Exception as e:
            self.console.print(f"[yellow]Event metrics error: {e}[/yellow]")
            
        return metrics
    
    def collect_meta_observer_metrics(self) -> MetaObserverMetrics:
        """Collect LNCP Meta/Observer system metrics and health."""
        metrics = MetaObserverMetrics()
        
        try:
            # Import Meta components
            sys.path.insert(0, os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), 'lncp'))
            from lncp.meta import get_meta_orchestrator
            
            # Get Meta orchestrator instance
            meta_orchestrator = get_meta_orchestrator()
            
            # Get overall status
            status = meta_orchestrator.get_status()
            metrics.meta_orchestrator_mode = status.get('mode', 'unknown')
            metrics.meta_cycle_count = status.get('cycle_count', 0)
            metrics.meta_actions_generated = status.get('total_actions_applied', 0)
            
            # Get system health summary
            if hasattr(meta_orchestrator, 'last_health') and meta_orchestrator.last_health:
                health = meta_orchestrator.last_health
                metrics.meta_orchestrator_health = health.score
                
            # Get v3.1.1 system health (achievement, retention, bundle, progressive)
            v311_health = meta_orchestrator.get_v311_health()
            metrics.achievement_observer_health = v311_health['achievement']['score']
            metrics.retention_observer_health = v311_health['retention']['score']
            metrics.bundle_tracker_health = v311_health['bundle']['score']
            metrics.progressive_tracker_health = v311_health['progressive']['score']
            
            # Specific metrics
            metrics.achievement_badge_engagement = v311_health['achievement']['badge_engagement']
            metrics.retention_mrr_saved_30d = v311_health['retention']['mrr_saved_30d']
            metrics.retention_save_rate = v311_health['retention']['save_rate']
            metrics.bundle_share = v311_health['bundle']['bundle_share']
            metrics.bundle_mrr = v311_health['bundle']['bundle_mrr']
            metrics.progressive_day7_conversion = v311_health['progressive']['day7_conversion']
            
            # Get SEO/Blog health
            seo_health = meta_orchestrator.get_seo_health()
            metrics.blog_observer_health = seo_health['overall_score']
            metrics.blog_seo_score = seo_health['seo_score']
            
            # Optimization metrics
            v311_summary = meta_orchestrator.get_v311_summary()
            metrics.optimizations_suggested = v311_summary['optimizations_suggested']
            metrics.optimizations_applied = v311_summary['actions_generated']
            
            # Issues collection
            all_issues = v311_summary.get('issues', [])
            seo_issues = seo_health.get('issues', [])
            metrics.meta_issues = all_issues[:3]  # Top 3 most critical
            metrics.observer_alerts = seo_issues[:2]  # Top 2 SEO alerts
            
            # Event processing (from event bus if available)
            if hasattr(meta_orchestrator, 'unified') and hasattr(meta_orchestrator.unified, 'event_bus'):
                event_metrics = meta_orchestrator.unified.event_bus.get_metrics()
                metrics.events_processed_24h = event_metrics.get('events_flushed', 0)
                metrics.events_queued = event_metrics.get('events_pending', 0)
                
            # Calculate prediction accuracy from outcome tracker
            if hasattr(meta_orchestrator, 'outcome_tracker'):
                summary = meta_orchestrator.outcome_tracker.get_learning_summary()
                metrics.meta_predictions_accuracy = summary.get('overall_success_rate', 0.0) * 100
                metrics.optimization_success_rate = summary.get('overall_success_rate', 0.0) * 100
                metrics.rollbacks_performed = summary.get('rollback_count', 0)
            
            # System uptime (from session start)
            session_duration = datetime.utcnow() - meta_orchestrator.session_start
            metrics.meta_system_uptime = session_duration.total_seconds() / 3600  # hours
            
        except ImportError as e:
            self.console.print(f"[yellow]Meta system not available: {e}[/yellow]")
            # Provide simulated data for demo purposes
            metrics.meta_orchestrator_health = 85.0
            metrics.meta_orchestrator_mode = "auto_safe"
            metrics.achievement_observer_health = 87.0
            metrics.retention_observer_health = 92.0
            metrics.bundle_tracker_health = 78.0
            metrics.progressive_tracker_health = 83.0
            metrics.blog_observer_health = 88.0
            metrics.blog_seo_score = 91.0
            metrics.retention_save_rate = 78.5
            metrics.meta_predictions_accuracy = 74.2
            metrics.optimization_success_rate = 89.1
            metrics.events_processed_24h = 1247
            metrics.meta_issues = ["Bundle pricing optimization pending review", "SEO refresh needed for 3 pages"]
            
        except Exception as e:
            self.console.print(f"[yellow]Meta observer metrics error: {e}[/yellow]")
            
        return metrics
    
    def collect_frontend_qa_metrics(self) -> FrontendQAMetrics:
        """Collect comprehensive frontend QA and user experience metrics."""
        metrics = FrontendQAMetrics()
        
        try:
            if not self.db_conn:
                return metrics
                
            cursor = self.db_conn.cursor()
            
            # Dashboard and page view metrics
            cursor.execute("""
                SELECT 
                    COUNT(*) FILTER (WHERE event = 'page_view') as total_views,
                    COUNT(DISTINCT session_id) as unique_journeys,
                    COUNT(*) FILTER (WHERE page LIKE '%dashboard%') as dashboard_loads,
                    COUNT(*) FILTER (WHERE event = 'profile_card_view') as profile_views
                FROM meta_events 
                WHERE created_at >= NOW() - INTERVAL '24 hours'
            """)
            
            row = cursor.fetchone()
            if row:
                metrics.total_page_views = row[0] or 0
                metrics.unique_user_journeys = row[1] or 0
                metrics.dashboard_loads = row[2] or 0
                metrics.profile_card_views = row[3] or 0
            
            # Profile distributions (All 10 profiles: ASSERTIVE, CONVERSATIONAL, MINIMAL, POETIC, DENSE, FORMAL, BALANCED, LONGFORM, INTERROGATIVE, HEDGED)
            cursor.execute("""
                SELECT profile, COUNT(*) 
                FROM analysis_results 
                WHERE created_at >= NOW() - INTERVAL '24 hours'
                AND profile IS NOT NULL
                GROUP BY profile
                ORDER BY COUNT(*) DESC
            """)
            
            metrics.profile_distributions = {row[0]: row[1] for row in cursor.fetchall()}
            
            # Stance distributions (OPEN, CLOSED, BALANCED, CONTRADICTORY)
            cursor.execute("""
                SELECT stance, COUNT(*) 
                FROM analysis_results 
                WHERE created_at >= NOW() - INTERVAL '24 hours'
                AND stance IS NOT NULL
                GROUP BY stance
                ORDER BY COUNT(*) DESC
            """)
            
            metrics.stance_distributions = {row[0]: row[1] for row in cursor.fetchall()}
            
            # Country-specific engagement (CA, GB, AU, NZ, US)
            cursor.execute("""
                SELECT 
                    u.country,
                    COUNT(DISTINCT me.session_id) as sessions,
                    COUNT(me.*) as total_events,
                    COUNT(*) FILTER (WHERE me.event = 'analysis_completed') as analyses,
                    COUNT(*) FILTER (WHERE me.event = 'dashboard_view') as dashboard_views,
                    AVG(EXTRACT(epoch FROM (me.created_at - u.created_at))/3600) as avg_user_age_hours
                FROM meta_events me
                LEFT JOIN users u ON me.user_id = u.id
                WHERE me.created_at >= NOW() - INTERVAL '24 hours'
                AND u.country IN ('CA', 'GB', 'AU', 'NZ', 'US')
                GROUP BY u.country
                ORDER BY total_events DESC
            """)
            
            for row in cursor.fetchall():
                country = row[0]
                metrics.country_engagement[country] = {
                    'sessions': row[1] or 0,
                    'total_events': row[2] or 0,
                    'analyses_completed': row[3] or 0,
                    'dashboard_views': row[4] or 0,
                    'avg_user_age_hours': float(row[5] or 0)
                }
            
            # Adaptive dashboard metrics
            cursor.execute("""
                SELECT 
                    COUNT(*) FILTER (WHERE data->>'dashboard_type' = 'adaptive') as adaptive_loads,
                    COUNT(*) FILTER (WHERE data->>'personalization' = 'enabled') as personalized_views,
                    COUNT(*) FILTER (WHERE event = 'dashboard_customization') as customizations,
                    COUNT(*) FILTER (WHERE event = 'tier_badge_click') as tier_interactions,
                    COUNT(*) FILTER (WHERE event = 'profile_evolution_view') as evolution_views
                FROM meta_events 
                WHERE created_at >= NOW() - INTERVAL '24 hours'
                AND (page LIKE '%dashboard%' OR event LIKE '%dashboard%')
            """)
            
            row = cursor.fetchone()
            if row:
                metrics.adaptive_dashboard_metrics = {
                    'adaptive_loads': row[0] or 0,
                    'personalized_views': row[1] or 0,
                    'customizations': row[2] or 0,
                    'tier_interactions': row[3] or 0,
                    'evolution_views': row[4] or 0
                }
            
            # Error rates by page
            cursor.execute("""
                SELECT 
                    page,
                    COUNT(*) FILTER (WHERE event = 'error') as errors,
                    COUNT(*) as total_events,
                    ROUND(100.0 * COUNT(*) FILTER (WHERE event = 'error') / COUNT(*), 2) as error_rate
                FROM meta_events 
                WHERE created_at >= NOW() - INTERVAL '24 hours'
                AND page IS NOT NULL AND page != ''
                GROUP BY page
                HAVING COUNT(*) > 10
                ORDER BY error_rate DESC
                LIMIT 10
            """)
            
            metrics.error_rates_by_page = {row[0]: row[3] for row in cursor.fetchall()}
            
            # Conversion funnel
            cursor.execute("""
                WITH funnel AS (
                    SELECT 
                        COUNT(*) FILTER (WHERE event = 'landing_page_view') as landing_views,
                        COUNT(*) FILTER (WHERE event = 'analysis_started') as analysis_starts,
                        COUNT(*) FILTER (WHERE event = 'analysis_completed') as analysis_completes,
                        COUNT(*) FILTER (WHERE event = 'results_viewed') as results_views,
                        COUNT(*) FILTER (WHERE event = 'signup_initiated') as signup_starts,
                        COUNT(*) FILTER (WHERE event = 'signup_completed') as signup_completes
                    FROM meta_events 
                    WHERE created_at >= NOW() - INTERVAL '24 hours'
                )
                SELECT * FROM funnel
            """)
            
            row = cursor.fetchone()
            if row:
                metrics.conversion_funnel = {
                    'landing_views': row[0] or 0,
                    'analysis_starts': row[1] or 0,
                    'analysis_completes': row[2] or 0,
                    'results_views': row[3] or 0,
                    'signup_starts': row[4] or 0,
                    'signup_completes': row[5] or 0
                }
            
            # Mobile vs Desktop
            cursor.execute("""
                SELECT 
                    CASE 
                        WHEN user_agent ILIKE '%mobile%' OR user_agent ILIKE '%android%' OR user_agent ILIKE '%iphone%' 
                        THEN 'mobile'
                        ELSE 'desktop'
                    END as device_type,
                    COUNT(*) as events
                FROM meta_events 
                WHERE created_at >= NOW() - INTERVAL '24 hours'
                AND user_agent IS NOT NULL
                GROUP BY device_type
            """)
            
            metrics.mobile_vs_desktop = {row[0]: row[1] for row in cursor.fetchall()}
            
        except Exception as e:
            self.console.print(f"[yellow]Frontend QA metrics error: {e}[/yellow]")
            
        return metrics
    
    def collect_comprehensive_analytics(self) -> Dict[str, Any]:
        """Collect comprehensive 10×4×5 profile×stance×country analytics."""
        analytics = {
            'profile_stance_matrix': {},
            'country_profile_distribution': {},
            'top_combinations': [],
            'coverage_stats': {}
        }
        
        try:
            if not self.db_conn:
                return analytics
                
            cursor = self.db_conn.cursor()
            
            # Profile × Stance Matrix (10×4 = 40 combinations)
            cursor.execute("""
                SELECT 
                    profile, 
                    stance, 
                    COUNT(*) as count,
                    ROUND(AVG(confidence), 2) as avg_confidence
                FROM analysis_results 
                WHERE created_at >= NOW() - INTERVAL '7 days'
                AND profile IS NOT NULL 
                AND stance IS NOT NULL
                GROUP BY profile, stance
                ORDER BY count DESC
            """)
            
            for row in cursor.fetchall():
                profile, stance, count, avg_conf = row
                key = f"{profile}_{stance}"
                analytics['profile_stance_matrix'][key] = {
                    'count': count,
                    'avg_confidence': float(avg_conf or 0)
                }
            
            # Country × Profile Distribution (5×10 = 50 combinations)
            cursor.execute("""
                SELECT 
                    u.country,
                    ar.profile,
                    COUNT(*) as count
                FROM analysis_results ar
                JOIN users u ON ar.user_id = u.id
                WHERE ar.created_at >= NOW() - INTERVAL '7 days'
                AND u.country IN ('CA', 'GB', 'AU', 'NZ', 'US')
                AND ar.profile IS NOT NULL
                GROUP BY u.country, ar.profile
                ORDER BY count DESC
            """)
            
            for row in cursor.fetchall():
                country, profile, count = row
                if country not in analytics['country_profile_distribution']:
                    analytics['country_profile_distribution'][country] = {}
                analytics['country_profile_distribution'][country][profile] = count
            
            # Top profile+stance combinations
            cursor.execute("""
                SELECT 
                    CONCAT(profile, ' + ', stance) as combination,
                    COUNT(*) as count,
                    ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER(), 2) as percentage
                FROM analysis_results 
                WHERE created_at >= NOW() - INTERVAL '7 days'
                AND profile IS NOT NULL 
                AND stance IS NOT NULL
                GROUP BY profile, stance
                ORDER BY count DESC
                LIMIT 15
            """)
            
            analytics['top_combinations'] = [
                {'combination': row[0], 'count': row[1], 'percentage': float(row[2])}
                for row in cursor.fetchall()
            ]
            
            # Coverage statistics
            cursor.execute("""
                SELECT 
                    COUNT(DISTINCT profile) as unique_profiles,
                    COUNT(DISTINCT stance) as unique_stances,
                    COUNT(DISTINCT CONCAT(profile, '_', stance)) as unique_combinations,
                    COUNT(*) as total_analyses
                FROM analysis_results 
                WHERE created_at >= NOW() - INTERVAL '7 days'
                AND profile IS NOT NULL 
                AND stance IS NOT NULL
            """)
            
            row = cursor.fetchone()
            if row:
                analytics['coverage_stats'] = {
                    'unique_profiles': row[0],
                    'unique_stances': row[1], 
                    'unique_combinations': row[2],
                    'total_analyses': row[3],
                    'profile_coverage': f"{row[0]}/10",
                    'stance_coverage': f"{row[1]}/4",
                    'combination_coverage': f"{row[2]}/40"
                }
                
        except Exception as e:
            self.console.print(f"[yellow]Comprehensive analytics error: {e}[/yellow]")
            
        return analytics
    
    def collect_marketing_funnel_metrics(self) -> MarketingFunnelMetrics:
        """Collect comprehensive marketing funnel and conversion metrics."""
        metrics = MarketingFunnelMetrics()
        
        try:
            if not self.db_conn:
                return metrics
                
            cursor = self.db_conn.cursor()
            
            # Anonymous user journey
            cursor.execute("""
                SELECT 
                    COUNT(DISTINCT session_id) as anonymous_sessions,
                    COUNT(*) FILTER (WHERE event = 'analysis_completed') as anonymous_analyses
                FROM meta_events 
                WHERE created_at >= NOW() - INTERVAL '7 days'
                AND user_id IS NULL
            """)
            
            row = cursor.fetchone()
            if row:
                metrics.anonymous_sessions = row[0] or 0
                metrics.anonymous_analyses = row[1] or 0
            
            # Blog system metrics
            cursor.execute("""
                SELECT 
                    COUNT(*) as blog_page_views,
                    COUNT(DISTINCT session_id) as blog_unique_visitors,
                    AVG(
                        CASE WHEN data->>'time_on_page' IS NOT NULL 
                        THEN (data->>'time_on_page')::float 
                        ELSE 0 END
                    ) as avg_time_on_page,
                    COUNT(*) FILTER (
                        WHERE data->>'bounce' = 'true'
                    ) * 100.0 / NULLIF(COUNT(*), 0) as bounce_rate
                FROM meta_events 
                WHERE event = 'blog_page_view'
                AND created_at >= NOW() - INTERVAL '7 days'
            """)
            
            row = cursor.fetchone()
            if row:
                metrics.blog_page_views = row[0] or 0
                metrics.blog_unique_visitors = row[1] or 0
                metrics.blog_avg_time_on_page = float(row[2] or 0)
                metrics.blog_bounce_rate = float(row[3] or 0)
            
            # Blog to analysis conversion rate
            cursor.execute("""
                WITH blog_sessions AS (
                    SELECT DISTINCT session_id 
                    FROM meta_events 
                    WHERE event = 'blog_page_view'
                    AND created_at >= NOW() - INTERVAL '7 days'
                ),
                analysis_sessions AS (
                    SELECT DISTINCT session_id 
                    FROM meta_events 
                    WHERE event = 'analysis_completed'
                    AND created_at >= NOW() - INTERVAL '7 days'
                ),
                signup_sessions AS (
                    SELECT DISTINCT session_id 
                    FROM meta_events 
                    WHERE event = 'signup_completed'
                    AND created_at >= NOW() - INTERVAL '7 days'
                )
                SELECT 
                    COUNT(DISTINCT bs.session_id) as blog_sessions,
                    COUNT(DISTINCT ase.session_id) as blog_to_analysis,
                    COUNT(DISTINCT sus.session_id) as blog_to_signup
                FROM blog_sessions bs
                LEFT JOIN analysis_sessions ase ON bs.session_id = ase.session_id
                LEFT JOIN signup_sessions sus ON bs.session_id = sus.session_id
            """)
            
            row = cursor.fetchone()
            if row:
                blog_sessions, blog_to_analysis, blog_to_signup = row
                if blog_sessions and blog_sessions > 0:
                    metrics.blog_to_analysis_rate = float(blog_to_analysis or 0) / blog_sessions * 100
                    metrics.blog_to_signup_rate = float(blog_to_signup or 0) / blog_sessions * 100
            
            # Top performing blog pages
            cursor.execute("""
                SELECT 
                    data->>'page_url' as page_url,
                    COUNT(*) as views
                FROM meta_events 
                WHERE event = 'blog_page_view'
                AND created_at >= NOW() - INTERVAL '7 days'
                AND data->>'page_url' IS NOT NULL
                GROUP BY data->>'page_url'
                ORDER BY COUNT(*) DESC
                LIMIT 10
            """)
            
            metrics.blog_top_pages = {row[0]: row[1] for row in cursor.fetchall() if row[0]}
            
            # Blog CTA performance
            cursor.execute("""
                SELECT 
                    data->>'cta_type' as cta_type,
                    COUNT(*) FILTER (WHERE event = 'cta_impression') as impressions,
                    COUNT(*) FILTER (WHERE event = 'cta_click') as clicks,
                    CASE 
                        WHEN COUNT(*) FILTER (WHERE event = 'cta_impression') > 0
                        THEN COUNT(*) FILTER (WHERE event = 'cta_click') * 100.0 / 
                             COUNT(*) FILTER (WHERE event = 'cta_impression')
                        ELSE 0 
                    END as ctr
                FROM meta_events 
                WHERE event IN ('cta_impression', 'cta_click')
                AND data->>'page_url' LIKE '%/blog/%'
                AND created_at >= NOW() - INTERVAL '7 days'
                AND data->>'cta_type' IS NOT NULL
                GROUP BY data->>'cta_type'
            """)
            
            for row in cursor.fetchall():
                cta_type, impressions, clicks, ctr = row
                if cta_type:
                    metrics.blog_cta_performance[cta_type] = float(ctr or 0)
            
            # SEO metrics (simulated from GSC-like data)
            cursor.execute("""
                SELECT 
                    SUM((data->>'impressions')::int) as total_impressions,
                    SUM((data->>'clicks')::int) as total_clicks,
                    AVG((data->>'position')::float) as avg_position,
                    COUNT(*) FILTER (
                        WHERE (data->>'position')::float BETWEEN 8 AND 20
                        AND (data->>'impressions')::int > 100
                    ) as keyword_opportunities
                FROM meta_events 
                WHERE event = 'gsc_performance'
                AND data->>'page_url' LIKE '%/blog/%'
                AND created_at >= NOW() - INTERVAL '7 days'
                AND data->>'impressions' IS NOT NULL
            """)
            
            row = cursor.fetchone()
            if row:
                impressions, clicks, position, opportunities = row
                metrics.seo_impressions = impressions or 0
                metrics.seo_clicks = clicks or 0
                metrics.seo_avg_position = float(position or 0)
                metrics.seo_keyword_opportunities = opportunities or 0
                if impressions and impressions > 0:
                    metrics.seo_ctr = float(clicks or 0) / impressions * 100
            
            # Content freshness score (based on publish/update dates)
            cursor.execute("""
                SELECT AVG(
                    CASE 
                        WHEN EXTRACT(days FROM (NOW() - (data->>'last_updated')::timestamp)) < 30 THEN 100
                        WHEN EXTRACT(days FROM (NOW() - (data->>'last_updated')::timestamp)) < 90 THEN 70
                        WHEN EXTRACT(days FROM (NOW() - (data->>'last_updated')::timestamp)) < 180 THEN 40
                        ELSE 20
                    END
                ) as freshness_score
                FROM meta_events 
                WHERE event = 'blog_content_registered'
                AND data->>'last_updated' IS NOT NULL
                AND created_at >= NOW() - INTERVAL '30 days'
            """)
            
            row = cursor.fetchone()
            if row:
                metrics.seo_content_freshness_score = float(row[0] or 0)
            
            # Social sharing and viral coefficient metrics
            cursor.execute("""
                SELECT 
                    data->>'platform' as platform,
                    COUNT(*) as shares
                FROM meta_events 
                WHERE event = 'social_share'
                AND data->>'page_url' LIKE '%/blog/%'
                AND created_at >= NOW() - INTERVAL '7 days'
                AND data->>'platform' IS NOT NULL
                GROUP BY data->>'platform'
            """)
            
            total_social_shares = 0
            for row in cursor.fetchall():
                platform, shares = row
                if platform:
                    metrics.social_shares_by_platform[platform] = shares
                    total_social_shares += shares
            
            metrics.social_shares_total = total_social_shares
            
            # Viral coefficient (new signups from social referrals / total social shares)
            cursor.execute("""
                SELECT COUNT(*) 
                FROM users 
                WHERE referrer_source IN ('facebook', 'twitter', 'linkedin', 'social')
                AND created_at >= NOW() - INTERVAL '7 days'
            """)
            
            row = cursor.fetchone()
            social_referral_signups = row[0] if row else 0
            if total_social_shares > 0:
                metrics.viral_coefficient = float(social_referral_signups) / total_social_shares
            
            # Referral traffic from social platforms
            cursor.execute("""
                SELECT COUNT(*) 
                FROM meta_events 
                WHERE event = 'page_view'
                AND data->>'referrer' ~* '(facebook|twitter|linkedin|instagram|tiktok|youtube)'
                AND data->>'page_url' LIKE '%/blog/%'
                AND created_at >= NOW() - INTERVAL '7 days'
            """)
            
            row = cursor.fetchone()
            metrics.referral_traffic = row[0] if row else 0
            
            # Social conversion rate (signups from social traffic / social traffic)
            if metrics.referral_traffic > 0:
                metrics.social_conversion_rate = float(social_referral_signups) / metrics.referral_traffic * 100
            
            # SEO optimization audit metrics (analyze static files)
            try:
                import os
                blog_dir = "/root/quirrely_v313_integrated/blog"
                if os.path.exists(blog_dir):
                    blog_files = [f for f in os.listdir(blog_dir) if f.endswith('.html') and f.startswith('how-')]
                    
                    pages_with_og = 0
                    pages_with_structured = 0
                    pages_with_meta = 0
                    
                    for filename in blog_files:
                        file_path = os.path.join(blog_dir, filename)
                        try:
                            with open(file_path, 'r', encoding='utf-8') as f:
                                content = f.read()
                                
                            if 'og:image' in content:
                                pages_with_og += 1
                            if 'application/ld+json' in content:
                                pages_with_structured += 1
                            if 'meta name="description"' in content:
                                pages_with_meta += 1
                        except Exception:
                            continue
                    
                    metrics.pages_with_og_images = pages_with_og
                    metrics.pages_with_structured_data = pages_with_structured
                    metrics.pages_with_meta_descriptions = pages_with_meta
                    metrics.pages_missing_seo_elements = len(blog_files) - min(pages_with_og, pages_with_structured, pages_with_meta)
                    
            except Exception as e:
                pass  # SEO audit failed, continue with other metrics
            
            # Page performance metrics (simulated from monitoring data)
            cursor.execute("""
                SELECT 
                    AVG((data->>'load_time_ms')::float) as avg_load_time,
                    AVG((data->>'mobile_score')::float) as mobile_score
                FROM meta_events 
                WHERE event = 'page_performance'
                AND data->>'page_url' LIKE '%/blog/%'
                AND created_at >= NOW() - INTERVAL '24 hours'
                AND data->>'load_time_ms' IS NOT NULL
            """)
            
            row = cursor.fetchone()
            if row:
                metrics.avg_page_load_speed = float(row[0] or 0)
                metrics.mobile_usability_score = float(row[1] or 0)
            
            # Signup funnel
            cursor.execute("""
                SELECT 
                    COUNT(*) FILTER (WHERE event_type = 'signup.started') as signup_attempts,
                    COUNT(*) FILTER (WHERE event_type = 'signup.completed') as signup_completions
                FROM conversion_events 
                WHERE created_at >= NOW() - INTERVAL '7 days'
            """)
            
            row = cursor.fetchone()
            if row:
                metrics.signup_attempts = row[0] or 0
                metrics.signup_completions = row[1] or 0
                if metrics.signup_attempts > 0:
                    metrics.signup_conversion_rate = (metrics.signup_completions / metrics.signup_attempts) * 100
            
            # Anonymous to signup conversion rate
            if metrics.anonymous_sessions > 0:
                metrics.anonymous_to_signup_rate = (metrics.signup_completions / metrics.anonymous_sessions) * 100
            
            # Signup sources
            cursor.execute("""
                SELECT 
                    data->>'source' as source,
                    COUNT(*) as count
                FROM conversion_events 
                WHERE event_type = 'signup.completed'
                AND created_at >= NOW() - INTERVAL '7 days'
                AND data->>'source' IS NOT NULL
                GROUP BY data->>'source'
                ORDER BY count DESC
            """)
            
            metrics.signup_sources = {row[0]: row[1] for row in cursor.fetchall()}
            
            # Tier distribution
            cursor.execute("""
                SELECT 
                    tier,
                    COUNT(*) as count
                FROM users 
                WHERE created_at >= NOW() - INTERVAL '30 days'
                GROUP BY tier
            """)
            
            for row in cursor.fetchall():
                tier, count = row
                if tier == 'free':
                    metrics.free_users = count
                elif tier == 'trial':
                    metrics.trial_users = count
                elif tier == 'pro':
                    metrics.pro_users = count
            
            # Trial funnel
            cursor.execute("""
                SELECT 
                    COUNT(*) FILTER (WHERE event_type = 'trial.started') as trial_starts,
                    COUNT(*) FILTER (WHERE event_type = 'trial.completed') as trial_completions,
                    COUNT(*) FILTER (WHERE event_type = 'subscription.created') as pro_conversions
                FROM conversion_events 
                WHERE created_at >= NOW() - INTERVAL '7 days'
            """)
            
            row = cursor.fetchone()
            if row:
                metrics.trial_starts = row[0] or 0
                metrics.trial_completions = row[1] or 0
                metrics.trial_conversions_to_pro = row[2] or 0
                if metrics.trial_starts > 0:
                    metrics.trial_conversion_rate = (metrics.trial_conversions_to_pro / metrics.trial_starts) * 100
            
            # Tier conversion rates
            total_users = metrics.free_users + metrics.trial_users + metrics.pro_users
            if total_users > 0:
                metrics.tier_conversion_rates = {
                    'free_to_trial': (metrics.trial_users / total_users) * 100 if total_users > 0 else 0,
                    'trial_to_pro': (metrics.pro_users / max(1, metrics.trial_users)) * 100,
                    'overall_to_pro': (metrics.pro_users / total_users) * 100
                }
            
            # Revenue attribution (last 30 days)
            cursor.execute("""
                SELECT 
                    data->>'amount' as amount,
                    data->>'plan' as plan,
                    COUNT(*) as count
                FROM conversion_events 
                WHERE event_type = 'subscription.created'
                AND created_at >= NOW() - INTERVAL '30 days'
                AND data->>'amount' IS NOT NULL
                GROUP BY data->>'amount', data->>'plan'
            """)
            
            mrr = 0.0
            for row in cursor.fetchall():
                amount_str, plan, count = row
                try:
                    amount = float(amount_str)
                    mrr += amount * count
                    if plan not in metrics.revenue_attribution:
                        metrics.revenue_attribution[plan] = 0.0
                    metrics.revenue_attribution[plan] += amount * count
                except (ValueError, TypeError):
                    continue
            
            metrics.monthly_recurring_revenue = mrr
            
            # Feature engagement leading to conversion
            cursor.execute("""
                SELECT 
                    feature_name,
                    COUNT(*) as usage_count,
                    COUNT(DISTINCT user_id) as unique_users,
                    AVG(CASE WHEN u.tier IN ('pro', 'curator') THEN 1.0 ELSE 0.0 END) as pro_conversion_rate
                FROM feature_access_log fal
                LEFT JOIN users u ON fal.user_id = u.id
                WHERE fal.created_at >= NOW() - INTERVAL '7 days'
                AND fal.allowed = true
                GROUP BY feature_name
                HAVING COUNT(*) > 10
                ORDER BY pro_conversion_rate DESC
            """)
            
            for row in cursor.fetchall():
                feature, usage, unique_users, conv_rate = row
                metrics.feature_engagement_scores[feature] = float(conv_rate or 0) * 100
                metrics.conversion_trigger_features[feature] = usage
            
            # Country-specific conversion patterns
            cursor.execute("""
                SELECT 
                    u.country,
                    COUNT(*) as total_users,
                    COUNT(*) FILTER (WHERE u.tier = 'free') as free_users,
                    COUNT(*) FILTER (WHERE u.tier = 'trial') as trial_users,
                    COUNT(*) FILTER (WHERE u.tier IN ('pro', 'curator')) as pro_users,
                    AVG(CASE WHEN u.tier IN ('pro', 'curator') THEN 1.0 ELSE 0.0 END) as conversion_rate
                FROM users u
                WHERE u.created_at >= NOW() - INTERVAL '30 days'
                AND u.country IN ('CA', 'GB', 'AU', 'NZ', 'US')
                GROUP BY u.country
                ORDER BY conversion_rate DESC
            """)
            
            for row in cursor.fetchall():
                country, total, free, trial, pro, conv_rate = row
                metrics.conversion_by_country[country] = {
                    'total_users': total,
                    'free_users': free,
                    'trial_users': trial,
                    'pro_users': pro,
                    'conversion_rate': float(conv_rate or 0) * 100
                }
            
            # Time-to-convert analytics
            cursor.execute("""
                WITH conversion_times AS (
                    SELECT 
                        user_id,
                        MIN(created_at) FILTER (WHERE tier = 'free') as signup_time,
                        MIN(created_at) FILTER (WHERE tier = 'trial') as trial_time,
                        MIN(created_at) FILTER (WHERE tier IN ('pro', 'curator')) as pro_time
                    FROM user_tier_history
                    WHERE created_at >= NOW() - INTERVAL '30 days'
                    GROUP BY user_id
                )
                SELECT 
                    AVG(EXTRACT(epoch FROM (trial_time - signup_time))/3600) as signup_to_trial_hours,
                    AVG(EXTRACT(epoch FROM (pro_time - trial_time))/3600) as trial_to_pro_hours
                FROM conversion_times
                WHERE signup_time IS NOT NULL
            """)
            
            row = cursor.fetchone()
            if row:
                metrics.avg_signup_to_trial_hours = float(row[0] or 0)
                metrics.avg_trial_to_pro_hours = float(row[1] or 0)
            
            # Retention rates (simplified)
            cursor.execute("""
                WITH cohort_retention AS (
                    SELECT 
                        DATE_TRUNC('week', created_at) as cohort_week,
                        COUNT(*) as total_users,
                        COUNT(*) FILTER (WHERE last_login >= NOW() - INTERVAL '7 days') as retained_7d,
                        COUNT(*) FILTER (WHERE last_login >= NOW() - INTERVAL '30 days') as retained_30d
                    FROM users 
                    WHERE created_at >= NOW() - INTERVAL '8 weeks'
                    AND created_at <= NOW() - INTERVAL '7 days'
                    GROUP BY cohort_week
                )
                SELECT 
                    AVG(retained_7d::float / NULLIF(total_users, 0)) as avg_retention_7d,
                    AVG(retained_30d::float / NULLIF(total_users, 0)) as avg_retention_30d
                FROM cohort_retention
            """)
            
            row = cursor.fetchone()
            if row:
                metrics.retention_day_7 = float(row[0] or 0) * 100
                metrics.retention_day_30 = float(row[1] or 0) * 100
            
            # Campaign performance (if UTM tracking exists)
            cursor.execute("""
                SELECT 
                    data->>'utm_campaign' as campaign,
                    COUNT(*) as signups,
                    COUNT(*) FILTER (WHERE u.tier IN ('pro', 'curator')) as conversions,
                    AVG(CASE WHEN u.tier IN ('pro', 'curator') THEN 1.0 ELSE 0.0 END) as conversion_rate
                FROM conversion_events ce
                LEFT JOIN users u ON ce.user_id = u.id
                WHERE ce.event_type = 'signup.completed'
                AND ce.created_at >= NOW() - INTERVAL '30 days'
                AND data->>'utm_campaign' IS NOT NULL
                GROUP BY data->>'utm_campaign'
                ORDER BY conversions DESC
                LIMIT 10
            """)
            
            for row in cursor.fetchall():
                campaign, signups, conversions, conv_rate = row
                metrics.campaign_performance[campaign] = {
                    'signups': signups,
                    'conversions': conversions,
                    'conversion_rate': float(conv_rate or 0) * 100
                }
                
        except Exception as e:
            self.console.print(f"[yellow]Marketing funnel metrics error: {e}[/yellow]")
            
        return metrics
    
    def display_security_view(self, metrics: SecurityMetrics):
        """Display security-focused metrics."""
        # Security Score Panel
        score_color = "green" if metrics.security_score >= 80 else "yellow" if metrics.security_score >= 60 else "red"
        score_panel = Panel(
            f"[bold {score_color}]{metrics.security_score:.1f}/100[/bold {score_color}]",
            title="Security Score",
            width=20
        )
        
        # Security Events Table
        events_table = Table(title="Security Events (24h)")
        events_table.add_column("Metric", style="cyan")
        events_table.add_column("Count", justify="right")
        
        events_table.add_row("Total Events", str(metrics.total_events))
        events_table.add_row("Threat Events", f"[red]{metrics.threat_events}[/red]" if metrics.threat_events > 0 else "0")
        events_table.add_row("Blocked IPs", f"[yellow]{metrics.blocked_ips}[/yellow]" if metrics.blocked_ips > 0 else "0")
        events_table.add_row("Failed Auth", f"[red]{metrics.failed_auths}[/red]" if metrics.failed_auths > 10 else str(metrics.failed_auths))
        events_table.add_row("Admin Access", str(metrics.admin_accesses))
        events_table.add_row("WebSocket Conns", str(metrics.websocket_connections))
        events_table.add_row("Active Sessions", str(metrics.active_sessions))
        
        # Threat Types Table
        threats_table = Table(title="Top Threat Types")
        threats_table.add_column("Type", style="red")
        threats_table.add_column("Count", justify="right")
        
        for threat_type, count in metrics.threats_by_type.items():
            threats_table.add_row(threat_type, str(count))
        
        self.console.print(score_panel)
        self.console.print()
        self.console.print(events_table)
        self.console.print()
        self.console.print(threats_table)
    
