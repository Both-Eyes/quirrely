#!/usr/bin/env python3
"""
QUIRRELY STATS (qstats) - DEMO VERSION
Shows qstats interface with mock data for demonstration
"""

import sys
import json
import time
from datetime import datetime
from typing import Dict, Any
from dataclasses import dataclass, asdict, field
from rich.console import Console
from rich.table import Table
from rich.panel import Panel
from rich.layout import Layout
from rich.text import Text

@dataclass
class SecurityMetrics:
    """Security-related metrics."""
    total_events: int = 0
    threat_events: int = 0
    blocked_ips: int = 0
    failed_auths: int = 0
    admin_accesses: int = 0
    websocket_connections: int = 0
    active_sessions: int = 0
    security_score: float = 100.0
    last_threat: str = None
    threats_by_type: Dict[str, int] = None

    def __post_init__(self):
        if self.threats_by_type is None:
            self.threats_by_type = {}

@dataclass  
class UserMetrics:
    """User and authentication metrics."""
    total_users: int = 0
    active_sessions: int = 0
    new_signups_today: int = 0
    login_attempts_today: int = 0
    successful_logins_today: int = 0
    failed_logins_today: int = 0
    countries_active: int = 0
    tier_distribution: Dict[str, int] = None
    
    def __post_init__(self):
        if self.tier_distribution is None:
            self.tier_distribution = {}

@dataclass
class FeatureMetrics:
    """Feature gate and access metrics."""
    total_checks: int = 0
    allowed_accesses: int = 0 
    denied_accesses: int = 0
    daily_limits_hit: int = 0
    feature_usage: Dict[str, int] = None
    tier_upgrade_requests: int = 0
    
    def __post_init__(self):
        if self.feature_usage is None:
            self.feature_usage = {}

@dataclass
class CollaborationMetrics:
    """Writing partnership and collaboration metrics."""
    # Partnership Statistics
    total_partnerships: int = 0
    active_partnerships: int = 0
    pending_invitations: int = 0
    completed_partnerships: int = 0
    cancelled_partnerships: int = 0
    
    # Invitation Flow
    invitations_sent_today: int = 0
    invitations_accepted_today: int = 0
    invitation_acceptance_rate: float = 0.0
    average_invitation_response_time: float = 0.0  # hours
    
    # Word Usage
    shared_words_used_today: int = 0
    solo_words_used_today: int = 0
    total_words_in_partnerships: int = 0
    partnership_word_utilization: float = 0.0  # percentage of allocated words used
    
    # Partnership Types
    partnerships_by_type: Dict[str, int] = None
    
    # Rate Limiting
    cancellations_blocked_today: int = 0
    users_rate_limited: int = 0
    
    # Engagement
    featured_submissions: int = 0
    partnership_duration_avg_days: float = 0.0
    
    def __post_init__(self):
        if self.partnerships_by_type is None:
            self.partnerships_by_type = {}

@dataclass
class SystemMetrics:
    """System performance metrics."""
    database_connections: int = 0
    redis_memory_usage: str = "0MB"
    avg_response_time: float = 0.0
    error_rate: float = 0.0
    uptime_hours: float = 0.0
    cpu_usage: float = 0.0
    memory_usage: float = 0.0

@dataclass
class EventMetrics:
    """Meta events and user behavior."""
    total_events: int = 0
    events_today: int = 0
    unique_sessions: int = 0
    unique_users: int = 0
    page_views: int = 0
    analyses_completed: int = 0
    events_by_type: Dict[str, int] = None
    
    def __post_init__(self):
        if self.events_by_type is None:
            self.events_by_type = {}

@dataclass
class MetaObserverMetrics:
    """LNCP Meta/Observer system metrics and health."""
    # Meta Orchestrator Health
    meta_orchestrator_health: float = 0.0
    meta_orchestrator_mode: str = "unknown"
    meta_cycle_count: int = 0
    meta_actions_generated: int = 0
    meta_actions_auto_applied: int = 0
    meta_actions_queued: int = 0
    meta_predictions_accuracy: float = 0.0
    meta_system_uptime: float = 0.0
    
    # Observer Health Scores (0-100)
    achievement_observer_health: float = 0.0
    retention_observer_health: float = 0.0
    bundle_tracker_health: float = 0.0
    progressive_tracker_health: float = 0.0
    blog_observer_health: float = 0.0
    revenue_observer_health: float = 0.0
    
    # Specific Observer Metrics
    achievement_badge_engagement: float = 0.0
    retention_mrr_saved_30d: float = 0.0
    retention_save_rate: float = 0.0
    bundle_share: float = 0.0
    bundle_mrr: float = 0.0
    progressive_day7_conversion: float = 0.0
    blog_seo_score: float = 0.0
    
    # Auto-Optimization Results
    optimizations_suggested: int = 0
    optimizations_applied: int = 0
    optimization_success_rate: float = 0.0
    rollbacks_performed: int = 0
    
    # Event Processing
    events_processed_24h: int = 0
    events_queued: int = 0
    event_processing_lag_ms: float = 0.0
    
    # Issues and Alerts
    meta_issues: list = field(default_factory=list)
    observer_alerts: list = field(default_factory=list)
    last_optimization: str = None

@dataclass
class FrontendQAMetrics:
    """Frontend QA and user experience metrics."""
    total_page_views: int = 0
    unique_user_journeys: int = 0
    dashboard_loads: int = 0
    profile_card_views: int = 0
    stance_distributions: Dict[str, int] = field(default_factory=dict)
    profile_distributions: Dict[str, int] = field(default_factory=dict)
    country_engagement: Dict[str, Dict[str, Any]] = field(default_factory=dict)
    adaptive_dashboard_metrics: Dict[str, Any] = field(default_factory=dict)
    error_rates_by_page: Dict[str, float] = field(default_factory=dict)
    conversion_funnel: Dict[str, int] = field(default_factory=dict)
    mobile_vs_desktop: Dict[str, int] = field(default_factory=dict)

@dataclass  
class MarketingFunnelMetrics:
    """Marketing funnel and conversion analytics for demo including blog system."""
    # Anonymous user journey
    anonymous_sessions: int = 0
    anonymous_analyses: int = 0
    anonymous_to_signup_rate: float = 0.0
    
    # Blog system metrics (NEW)
    blog_page_views: int = 0
    blog_unique_visitors: int = 0
    blog_to_analysis_rate: float = 0.0
    blog_to_signup_rate: float = 0.0
    blog_avg_time_on_page: float = 0.0
    blog_bounce_rate: float = 0.0
    blog_top_pages: Dict[str, int] = field(default_factory=dict)
    blog_cta_performance: Dict[str, float] = field(default_factory=dict)
    
    # SEO metrics (NEW)
    seo_impressions: int = 0
    seo_clicks: int = 0
    seo_ctr: float = 0.0
    seo_avg_position: float = 0.0
    seo_keyword_opportunities: int = 0
    seo_content_freshness_score: float = 0.0
    
    # Viral coefficient and social sharing (NEW)
    social_shares_total: int = 0
    social_shares_by_platform: Dict[str, int] = field(default_factory=dict)
    viral_coefficient: float = 0.0
    referral_traffic: int = 0
    social_conversion_rate: float = 0.0
    
    # SEO optimization metrics (NEW)
    pages_with_og_images: int = 0
    pages_with_structured_data: int = 0
    pages_with_meta_descriptions: int = 0
    pages_missing_seo_elements: int = 0
    avg_page_load_speed: float = 0.0
    mobile_usability_score: float = 0.0
    
    # Signup funnel
    signup_attempts: int = 0
    signup_completions: int = 0
    signup_conversion_rate: float = 0.0
    signup_sources: Dict[str, int] = field(default_factory=dict)
    
    # Tier progression funnel
    free_users: int = 0
    trial_users: int = 0
    pro_users: int = 0
    tier_conversion_rates: Dict[str, float] = field(default_factory=dict)
    
    # Trial funnel
    trial_starts: int = 0
    trial_completions: int = 0
    trial_conversions_to_pro: int = 0
    trial_conversion_rate: float = 0.0
    
    # Pro conversion and revenue
    pro_conversions: int = 0
    revenue_attribution: Dict[str, float] = field(default_factory=dict)
    monthly_recurring_revenue: float = 0.0
    
    # Feature engagement leading to conversion
    feature_engagement_scores: Dict[str, float] = field(default_factory=dict)
    conversion_trigger_features: Dict[str, int] = field(default_factory=dict)
    
    # Country-specific conversion patterns
    conversion_by_country: Dict[str, Dict[str, Any]] = field(default_factory=dict)
    
    # Time-to-convert analytics
    avg_signup_to_trial_hours: float = 0.0
    avg_trial_to_pro_hours: float = 0.0
    
    # Retention
    retention_day_7: float = 0.0
    retention_day_30: float = 0.0
    
    # Campaign performance
    campaign_performance: Dict[str, Dict[str, Any]] = field(default_factory=dict)

