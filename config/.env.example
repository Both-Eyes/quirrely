# ═══════════════════════════════════════════════════════════════════════════
# QUIRRELY ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════════════
# 
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Required for: Development, Staging, Production
# ═══════════════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────────────
# ENVIRONMENT
# ───────────────────────────────────────────────────────────────────────────

QUIRRELY_ENV=development  # development | staging | production


# ───────────────────────────────────────────────────────────────────────────
# DATABASE (Supabase)
# ───────────────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...


# ───────────────────────────────────────────────────────────────────────────
# AUTHENTICATION (Supabase Auth)
# ───────────────────────────────────────────────────────────────────────────

JWT_SECRET=your-jwt-secret-from-supabase

# Google OAuth (get from Google Cloud Console)
# NOTE: Apple Sign-In explicitly NOT supported
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx


# ───────────────────────────────────────────────────────────────────────────
# PAYMENTS (Stripe)
# ───────────────────────────────────────────────────────────────────────────

# Use test keys for development, live keys for production
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# NOTE: All prices in CAD, GBP, AUD, NZD, EUR — NEVER USD


# ───────────────────────────────────────────────────────────────────────────
# EMAIL (Resend)
# ───────────────────────────────────────────────────────────────────────────

RESEND_API_KEY=re_xxx
EMAIL_FROM_TRANSACTIONAL=hello@quirrely.com
EMAIL_FROM_NOREPLY=noreply@quirrely.com
EMAIL_SUPPORT=support@quirrely.com


# ───────────────────────────────────────────────────────────────────────────
# ANALYTICS (Plausible — Privacy-focused, no cookies)
# ───────────────────────────────────────────────────────────────────────────

PLAUSIBLE_DOMAIN=quirrely.com
PLAUSIBLE_API_KEY=xxx


# ───────────────────────────────────────────────────────────────────────────
# ERROR TRACKING (Sentry)
# ───────────────────────────────────────────────────────────────────────────

SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ENVIRONMENT=development


# ───────────────────────────────────────────────────────────────────────────
# MONITORING & ALERTS
# ───────────────────────────────────────────────────────────────────────────

ALERT_EMAIL=alerts@quirrely.com
SLACK_ALERT_WEBHOOK=https://hooks.slack.com/services/xxx


# ───────────────────────────────────────────────────────────────────────────
# DOMAINS (Multi-country)
# ───────────────────────────────────────────────────────────────────────────

DOMAIN_GLOBAL=quirrely.com
DOMAIN_CA=quirrely.ca
DOMAIN_UK=quirrely.co.uk
DOMAIN_AU=quirrely.com.au
DOMAIN_NZ=quirrely.co.nz
DOMAIN_API=api.quirrely.com


# ───────────────────────────────────────────────────────────────────────────
# URLS
# ───────────────────────────────────────────────────────────────────────────

API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
API_PORT=8000
API_HOST=0.0.0.0


# ───────────────────────────────────────────────────────────────────────────
# AFFILIATE PROGRAMS (by country)
# ───────────────────────────────────────────────────────────────────────────

# Canada - Indigo (NOT Amazon)
INDIGO_AFFILIATE_ID=your-indigo-affiliate-id

# UK - Bookshop.org UK (NOT Amazon)
BOOKSHOP_UK_AFFILIATE_ID=your-bookshop-uk-affiliate-id

# Australia - Booktopia (NOT Amazon)
BOOKTOPIA_AFFILIATE_ID=your-booktopia-affiliate-id

# New Zealand - Mighty Ape (NOT Amazon)
MIGHTYAPE_AFFILIATE_ID=your-mightyape-affiliate-id


# ───────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ───────────────────────────────────────────────────────────────────────────

# Override feature flags (optional, for testing)
# FF_NEW_VOICE_ALGORITHM=true
# FF_DARK_MODE=true
# FF_READING_RECOMMENDATIONS=true


# ───────────────────────────────────────────────────────────────────────────
# DEVELOPMENT ONLY
# ───────────────────────────────────────────────────────────────────────────

# Skip email verification in development
# DEV_SKIP_EMAIL_VERIFICATION=true

# Enable debug mode
# DEBUG=true


# ═══════════════════════════════════════════════════════════════════════════
# EXCLUSION LIST REMINDER
# ═══════════════════════════════════════════════════════════════════════════
#
# The following are NEVER used in Quirrely:
#
# ❌ USD — Use CAD, GBP, AUD, NZD, EUR only
# ❌ Amazon — Use Indigo, Bookshop.org, Booktopia, Mighty Ape
# ❌ X/Twitter — No social sharing to X
# ❌ Apple Sign-In — Google only
# ❌ Shiny Gold (#FFD700) — Use Soft Gold (#D4A574)
#
# ═══════════════════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════════════════
# PRE-LAUNCH CHECKLIST
# ═══════════════════════════════════════════════════════════════════════════
#
# Before deploying to production, verify:
#
# [ ] All xxx placeholders replaced with real values
# [ ] Stripe keys are LIVE keys (pk_live_, sk_live_)
# [ ] QUIRRELY_ENV=production
# [ ] SENTRY_ENVIRONMENT=production
# [ ] Database URL points to production database
# [ ] Webhook secrets are configured
# [ ] This file is NOT committed to git
#
# ═══════════════════════════════════════════════════════════════════════════
