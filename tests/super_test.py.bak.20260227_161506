def read_env():
    env={}
    try:
        import os
        with open(os.path.join(APP_DIR,".env")) as f:
            for line in f:
                line=line.strip()
                if line and not line.startswith("#") and "=" in line:
                    k,v=line.split("=",1); env[k.strip()]=v.strip()
    except: pass
    return env

