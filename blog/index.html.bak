<!DOCTYPE html>
<html lang="en">
<head>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-HQ818WM2YB"></script>
<script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag("js",new Date());gtag("config","G-HQ818WM2YB");</script>
  <link rel="icon" type="image/svg+xml" href="/assets/logo/favicon.svg">
  <meta charset="UTF-8">
  <link rel="stylesheet" href="/assets/css/compat.css">
  <script src="/assets/js/compat.js" defer></script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blog | Quirrely — The curious way to find your writing voice</title>
  <meta name="description" content="Explore writing styles, voice profiles, and tips to strengthen your unique writing identity. Updated weekly with featured writers.">
  <meta property="og:title" content="Quirrely Blog — Writing Voice Insights">
  <meta property="og:description" content="Explore writing styles and discover your unique voice.">
  <meta property="og:type" content="website">
  <link rel="canonical" href="https://quirrely.ca/blog">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,600&family=Nunito+Sans:ital,wght@0,400;0,500;0,600;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #FFFBF5;
      --card: #FFFFFF;
      --ink: #2D3436;
      --muted: #6B6560;
      --primary: #FF6B6B;
      --secondary: #7CAE9E;
      --pro: #FF6B6B;
      --border: #E8E2DA;
      --shadow: 0 2px 12px rgba(120,100,80,0.06);
    }
    
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      font-family: 'Nunito Sans', -apple-system, sans-serif;
      background: var(--bg);
      color: var(--ink);
      line-height: 1.6;
    }
    
    /* ===== UNIFIED HEADER ===== */
    .site-header {
      background: linear-gradient(180deg, #FFFDF9, #FFFBF5);
      border-bottom: 1px solid #E8E2DA;
      padding: 0 2rem;
      position: sticky; top: 0; z-index: 100;
      box-shadow: 0 1px 8px rgba(120,100,80,0.06);
    }
    .site-header-inner {
      max-width: 960px; margin: 0 auto;
      display: flex; align-items: center; height: 56px; gap: 2rem;
    }
    .site-logo {
      display: flex; align-items: center; gap: 10px;
      text-decoration: none; flex-shrink: 0;
    }
    .site-logo svg { width: 28px; height: 42px; }
    .site-logo-text {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 1.25rem; font-weight: 700; color: #2D2D2D;
    }
    .site-logo-text .re { color: #FF6B6B; }
    .site-logo-text .ly { font-style: italic; font-weight: 500; }
    .site-nav {
      display: flex; align-items: center; gap: 4px;
    }
    .site-nav a {
      padding: 8px 14px; font-size: 0.875rem; font-weight: 500;
      color: #6B6560; text-decoration: none; position: relative;
      transition: color 0.2s; border-radius: 6px;
    }
    .site-nav a::after {
      content: ''; position: absolute; bottom: 2px; left: 14px; right: 14px;
      height: 2px; background: #FF6B6B; border-radius: 1px;
      transform: scaleX(0); transition: transform 0.25s cubic-bezier(0.25,0.46,0.45,0.94);
    }
    .site-nav a:hover { color: #FF6B6B; }
    .site-nav a:hover::after { transform: scaleX(1); }
    .site-nav a.active { color: #FF6B6B; }
    .site-nav a.active::after { transform: scaleX(1); }
    .site-header-right {
      margin-left: auto; display: flex; align-items: center; gap: 12px;
    }
    .site-header-right .signin-link {
      font-size: 0.875rem; font-weight: 500; color: #6B6560;
      text-decoration: none; transition: color 0.2s;
    }
    .site-header-right .signin-link:hover { color: #FF6B6B; }
    .site-header-right .signup-btn {
      padding: 0.5rem 1.25rem;
      background: linear-gradient(135deg, #FF6B6B, #E85858);
      color: white; border-radius: 6px; text-decoration: none;
      font-family: 'Fraunces', Georgia, serif;
      font-size: 0.85rem; font-weight: 600;
      transition: transform 0.15s, box-shadow 0.15s;
      box-shadow: 0 2px 8px rgba(255,107,107,0.25);
    }
    .site-header-right .signup-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(255,107,107,0.35); }
    .site-hamburger {
      display: none; background: none; border: none; cursor: pointer;
      padding: 4px; color: #2D2D2D; margin-left: auto;
    }
    .site-mobile-menu {
      display: none; position: fixed; top: 56px; left: 0; right: 0;
      background: #FFFDF9; border-bottom: 1px solid #E8E2DA;
      box-shadow: 0 8px 32px rgba(120,100,80,0.12); padding: 0.75rem; z-index: 99;
    }
    .site-mobile-menu.show { display: block; }
    .site-mobile-menu a {
      display: block; padding: 0.75rem 1rem; font-size: 0.95rem;
      color: #2D2D2D; text-decoration: none; border-radius: 6px;
    }
    .site-mobile-menu a:hover { background: rgba(0,0,0,0.04); }
    .site-mobile-menu a.active { color: #FF6B6B; }
    .site-mobile-menu .mobile-signup {
      margin: 0.5rem 1rem; padding: 0.65rem 1rem;
      background: linear-gradient(135deg, #FF6B6B, #E85858);
      color: white; border-radius: 6px; text-align: center; font-weight: 600;
    }
    @media (max-width: 768px) {
      .site-header { padding: 0 1rem; }
      .site-nav { display: none; }
      .site-header-right { display: none; }
      .site-hamburger { display: block; }
    }
    
    /* Hero */
    .hero {
      background: linear-gradient(135deg, var(--primary), #FF8E8E);
      color: white;
      padding: 4rem 2rem;
      text-align: center;
    }
    
    .hero h1 {
      font-family: 'Fraunces', -apple-system, sans-serif;
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
    }
    
    .hero p {
      font-size: 1.1rem;
      opacity: 0.9;
      max-width: 500px;
      margin: 0 auto;
    }
    
    /* Main Layout */
    .main {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem;
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 2rem;
    }
    
    @media (max-width: 900px) {
      .main { grid-template-columns: 1fr; }
    }
    
    /* Featured Section */
    .featured-section {
      margin-bottom: 2rem;
    }
    
    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
    }
    
    .section-title {
      font-size: 1.1rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    
    .section-link {
      font-size: 0.85rem;
      color: var(--pro);
      text-decoration: none;
    }
    
    .section-link:hover { text-decoration: underline; }
    
    /* Featured Writers Grid */
    .featured-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
    
    @media (max-width: 600px) {
      .featured-grid { grid-template-columns: 1fr; }
    }
    
    .featured-card {
      background: var(--card);
      border-radius: 12px;
      padding: 1.25rem;
      border: 1px solid var(--border);
      transition: transform 0.2s, box-shadow 0.2s;
      text-decoration: none;
      color: inherit;
      display: block;
    }
    
    .featured-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow);
    }
    
    .featured-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.75rem;
    }
    
    .featured-flag { font-size: 1.5rem; }
    
    .featured-info h3 {
      font-size: 0.95rem;
      margin-bottom: 0.1rem;
    }
    
    .featured-profile {
      font-size: 0.75rem;
      color: var(--pro);
      font-weight: 600;
    }
    
    .featured-excerpt {
      font-size: 0.85rem;
      color: var(--muted);
      font-style: italic;
      line-height: 1.5;
    }
    
    .pro-badge {
      display: inline-block;
      background: var(--pro);
      color: white;
      font-size: 0.6rem;
      padding: 0.1rem 0.4rem;
      border-radius: 3px;
      font-weight: 700;
      margin-left: 0.4rem;
      vertical-align: middle;
    }
    
    /* Blog Posts */
    .posts-section {
      margin-bottom: 2rem;
    }
    
    .post-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    
    .post-card {
      background: var(--card);
      border-radius: 12px;
      padding: 1.25rem;
      border: 1px solid var(--border);
      display: flex;
      gap: 1rem;
      text-decoration: none;
      color: inherit;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    
    .post-card:hover {
      transform: translateX(4px);
      box-shadow: var(--shadow);
    }
    
    .post-icon {
      width: 60px;
      height: 60px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.75rem;
      flex-shrink: 0;
    }
    
    .post-content {
      flex: 1;
    }
    
    .post-category {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--muted);
      margin-bottom: 0.25rem;
    }
    
    .post-title {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 0.25rem;
      line-height: 1.3;
    }
    
    .post-meta {
      font-size: 0.8rem;
      color: var(--muted);
    }
    
    .post-locked {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      background: var(--pro);
      color: white;
      font-size: 0.65rem;
      padding: 0.15rem 0.4rem;
      border-radius: 3px;
      font-weight: 600;
      margin-left: 0.5rem;
    }
    
    /* Sidebar */
    .sidebar {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    
    .sidebar-card {
      background: var(--card);
      border-radius: 12px;
      padding: 1.25rem;
      border: 1px solid var(--border);
    }
    
    .sidebar-card h3 {
      font-size: 0.9rem;
      font-weight: 700;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    
    /* Profile Categories */
    .profile-list {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    
    .profile-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.5rem;
      border-radius: 8px;
      text-decoration: none;
      color: inherit;
      transition: background 0.2s;
    }
    
    .profile-item:hover {
      background: var(--bg);
    }
    
    .profile-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
    }
    
    .profile-name {
      flex: 1;
      font-size: 0.85rem;
    }
    
    /* Newsletter CTA */
    .newsletter-cta {
      background: linear-gradient(135deg, var(--pro), #8B7CF7);
      color: white;
      border-radius: 12px;
      padding: 1.5rem;
      text-align: center;
    }
    
    .newsletter-cta h3 {
      font-size: 1rem;
      margin-bottom: 0.5rem;
      color: white;
    }
    
    .newsletter-cta p {
      font-size: 0.85rem;
      opacity: 0.9;
      margin-bottom: 1rem;
    }
    
    .newsletter-form {
      display: flex;
      gap: 0.5rem;
    }
    
    .newsletter-form input {
      flex: 1;
      padding: 0.6rem 0.75rem;
      border: none;
      border-radius: 6px;
      font-size: 0.85rem;
    }
    
    .newsletter-form button {
      background: white;
      color: var(--pro);
      border: none;
      padding: 0.6rem 1rem;
      border-radius: 6px;
      font-weight: 600;
      font-size: 0.85rem;
      cursor: pointer;
    }
    
    /* Countries */
    .country-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    
    .country-tag {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      background: var(--bg);
      padding: 0.4rem 0.75rem;
      border-radius: 20px;
      font-size: 0.8rem;
      text-decoration: none;
      color: var(--ink);
    }
    
    .country-tag:hover {
      background: var(--border);
    }
    
    /* Pagination */
    .pagination {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
      margin-top: 2rem;
    }
    
    .pagination a {
      padding: 0.5rem 0.9rem;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 6px;
      text-decoration: none;
      color: var(--ink);
      font-size: 0.9rem;
    }
    
    .pagination a:hover {
      border-color: var(--primary);
    }
    
    .pagination a.active {
      background: var(--primary);
      color: white;
      border-color: var(--primary);
    }
    
    /* ===== UNIFIED FOOTER ===== */
    .site-footer {
      text-align: center; padding: 2rem; border-top: 1px solid #E8E2DA;
      font-size: 0.85rem; color: #6B6560; margin-top: 2rem;
    }
    .site-footer a { color: #6B6560; text-decoration: none; transition: color 0.2s; }
    .site-footer a:hover { color: #FF6B6B; }
    .site-footer .footer-brand { font-family: 'Fraunces', Georgia, serif; font-weight: 600; color: #2D2D2D; }
    .footer-social { display: inline-flex; align-items: center; gap: 0.75rem; margin-left: 0.5rem; }
    .footer-social a { opacity: 0.6; }
    .footer-social a:hover { opacity: 1; }

    .filter-bar { margin-bottom: 1.5rem; }
    .filter-row { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.75rem; }
    .filter-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--muted); margin-bottom: 0.4rem; font-weight: 600; }
    .filter-btn { padding: 0.35rem 0.85rem; border: 1px solid var(--border); border-radius: 20px; background: var(--card); color: var(--ink); font-size: 0.82rem; cursor: pointer; transition: all 0.15s; font-family: inherit; }
    .filter-btn:hover { border-color: var(--primary); color: var(--primary); }
    .filter-btn.active { background: var(--primary); border-color: var(--primary); color: white; }
    .post-excerpt{font-size:0.82rem;color:var(--muted);margin-top:0.3rem;line-height:1.5;}
    .post-count { font-size: 0.82rem; color: var(--muted); margin-bottom: 1rem; }
    .post-card[style*="display: none"] { display: none !important; }
  </style>
</head>
<body>
  <!-- Unified Header -->
  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="site-logo">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 120" width="28" height="42">
          <path d="M58 112 Q85 98,94 62 Q100 26,74 8 Q50-8,42 22 Q38 44,54 60 Q70 78,62 100 Q58 110,58 112" fill="#FFFEF9" stroke="#E0DBD5" stroke-width="1.4"/>
          <ellipse cx="40" cy="98" rx="22" ry="26" fill="#FFFEF9" stroke="#E0DBD5" stroke-width="1.4"/>
          <path d="M20 68 Q12 72,14 80 Q16 86,24 88 L32 86" fill="#FFFEF9" stroke="#E0DBD5" stroke-width="1.8"/>
          <path d="M60 68 Q68 72,66 80 Q64 86,56 88 L48 86" fill="#FFFEF9" stroke="#E0DBD5" stroke-width="1.8"/>
          <ellipse cx="28" cy="86" rx="7" ry="5" fill="#FFFEF9"/><ellipse cx="52" cy="86" rx="7" ry="5" fill="#FFFEF9"/>
          <ellipse cx="40" cy="78" rx="9" ry="4" fill="#E85A5A"/><rect x="38.5" y="74" width="3" height="4" rx="1.5" fill="#D4504A"/>
          <path d="M31 78 Q30 94,40 99 Q50 94,49 78 Z" fill="#FF6B6B"/>
          <ellipse cx="40" cy="50" rx="22" ry="20" fill="#FFFEF9" stroke="#E0DBD5" stroke-width="1.4"/>
          <ellipse cx="24" cy="30" rx="8" ry="14" fill="#D4CCC4" opacity="0.6"/>
          <ellipse cx="56" cy="30" rx="8" ry="14" fill="#D4CCC4" opacity="0.6"/>
          <ellipse cx="32" cy="48" rx="5.5" ry="6" fill="#1a1a1a"/><ellipse cx="48" cy="48" rx="5.5" ry="6" fill="#1a1a1a"/>
          <circle cx="33" cy="46.5" r="2" fill="#FFF"/><circle cx="49" cy="46.5" r="2" fill="#FFF"/>
          <ellipse cx="40" cy="60" rx="4.5" ry="3.5" fill="#4A4A4A"/>
        </svg>
        <span class="site-logo-text">Quir<span class="re">re</span><span class="ly">ly</span></span>
      </a>
      <nav class="site-nav" id="main-nav">
        <a href="/">Home</a>
        <a href="/blog" class="active">Blog</a>
        <a href="/faq">FAQ</a>
        <a href="/billing/upgrade.html">Pricing</a>
      </nav>
      <div class="site-header-right">
        <a href="/auth/login.html" class="signin-link" id="nav-signin">Sign In</a>
        <a href="/auth/signup.html" class="signup-btn" id="nav-signup">Sign Up</a>
      </div>
      <button class="site-hamburger" onclick="document.getElementById('siteMobileMenu').classList.toggle('show')" aria-label="Menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </header>
  <div class="site-mobile-menu" id="siteMobileMenu">
    <a href="/">Home</a>
    <a href="/blog" class="active">Blog</a>
    <a href="/faq">FAQ</a>
    <a href="/billing/upgrade.html">Pricing</a>
    <a href="/auth/login.html">Sign In</a>
    <a href="/auth/signup.html" class="mobile-signup">Sign Up</a>
  </div>
  
  <!-- Main Content -->
  <main class="main">
    <div class="content">
      
      <section class="posts-section">
        <div class="filter-bar">
          <div class="filter-label">Type</div>
          <div class="filter-row" id="type-filters">
            <button class="filter-btn active" data-filter="type" data-val="all">All (88)</button>
            <button class="filter-btn" data-filter="type" data-val="guide">Guides (7)</button>
            <button class="filter-btn" data-filter="type" data-val="how">How I Write (41)</button>
            <button class="filter-btn" data-filter="type" data-val="combo">Reading Taste (40)</button>
          </div>
          <div class="filter-label">Profile</div>
          <div class="filter-row" id="profile-filters">
            <button class="filter-btn active" data-filter="profile" data-val="all">All</button>
            <button class="filter-btn" data-filter="profile" data-val="assertive">Assertive</button><button class="filter-btn" data-filter="profile" data-val="poetic">Poetic</button><button class="filter-btn" data-filter="profile" data-val="minimal">Minimal</button><button class="filter-btn" data-filter="profile" data-val="dense">Dense</button><button class="filter-btn" data-filter="profile" data-val="conversational">Conversational</button><button class="filter-btn" data-filter="profile" data-val="hedged">Hedged</button><button class="filter-btn" data-filter="profile" data-val="interrogative">Interrogative</button><button class="filter-btn" data-filter="profile" data-val="longform">Longform</button><button class="filter-btn" data-filter="profile" data-val="contradictory">Contradictory</button>
          </div>
        </div>
        <div class="post-count" id="post-count">Showing all 88 posts</div>
        <div class="post-list" id="post-list">
        <a href="/blog/what-is-writing-voice" class="post-card" data-type="guide" data-profile="other"><div class="post-icon" style="background:#FF6B6B;">📖</div><div class="post-content"><div class="post-category">Guide</div><h3 class="post-title">What Is Writing Voice</h3></div></a>
<a href="/blog/canadian-writing-style" class="post-card" data-type="guide" data-profile="other"><div class="post-icon" style="background:#FF6B6B;">📖</div><div class="post-content"><div class="post-category">Guide</div><h3 class="post-title">Canadian Writing Style</h3></div></a>
<a href="/blog/understanding-9-profiles" class="post-card" data-type="guide" data-profile="other"><div class="post-icon" style="background:#FF6B6B;">📖</div><div class="post-content"><div class="post-category">Guide</div><h3 class="post-title">Understanding 9 Profiles</h3></div></a>
<a href="/blog/voice-reflects-thinking" class="post-card" data-type="guide" data-profile="other"><div class="post-icon" style="background:#FF6B6B;">📖</div><div class="post-content"><div class="post-category">Guide</div><h3 class="post-title">Voice Reflects Thinking</h3></div></a>
<a href="/blog/business-writing-voice" class="post-card" data-type="guide" data-profile="other"><div class="post-icon" style="background:#FF6B6B;">📖</div><div class="post-content"><div class="post-category">Guide</div><h3 class="post-title">Business Writing Voice</h3></div></a>
