  <script>
  document.getElementById('newsletter-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var email = document.getElementById('nl-email').value.trim();
    var btn = document.getElementById('nl-btn');
    var msg = document.getElementById('nl-msg');
    if (!email) return;
    btn.disabled = true;
    btn.textContent = '...';
    try {
      var r = await fetch('/api/v2/newsletter/subscribe', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({email: email, source: 'blog_sidebar'})
      });
      var d = await r.json();
      if (d.success) {
        msg.style.display = 'block';
        msg.style.color = '#FFFFFF'; msg.style.fontWeight = '600';
        msg.textContent = d.new ? 'You are in! Check your inbox.' : 'You are already subscribed!';
        document.getElementById('nl-email').value = '';
      } else {
        msg.style.display = 'block';
        msg.style.color = '#FFD0D0'; msg.style.fontWeight = '600';
        msg.textContent = d.error || 'Something went wrong.';
      }
    } catch(err) {
      msg.style.display = 'block';
      msg.style.color = '#FFD0D0'; msg.style.fontWeight = '600';
      msg.textContent = 'Connection error. Try again.';
    }
    btn.disabled = false;
    btn.textContent = 'Join';
  });
  </script>
<script>
(function(){
  var s=localStorage.getItem('quirrely_session');
  if(!s)return;
  var nav=document.getElementById('main-nav')||document.querySelector('.nav');
  if(nav){
    var u=localStorage.getItem('quirrely_user');
    var p;try{p=JSON.parse(u);}catch(e){p={};}
    var _d=(p&&p.share_slug)?'/user/'+p.share_slug:'/dashboard';nav.innerHTML='<a href="'+_d+'">Dashboard</a><a href="/blog" class="active">Blog</a><a href="/faq">FAQ</a><a href="/settings">Settings</a>';
    var av=document.createElement('a');
    av.href=_d;
    av.style.cssText='width:28px;height:28px;border-radius:50%;background:#FF6B6B;display:inline-flex;align-items:center;justify-content:center;color:white;font-size:0.75rem;font-weight:600;text-decoration:none;margin-left:0.5rem;';
    try{var ud=JSON.parse(u);av.textContent=(ud.display_name||ud.email||'?')[0].toUpperCase();}catch(e){av.textContent='?';}
    nav.appendChild(av);
  }
})();
</script>

<script>
(function(){
  var activeType = 'all', activeProfile = 'all';
  function applyFilters(){
    var cards = document.querySelectorAll('#post-list .post-card');
    var shown = 0;
    cards.forEach(function(card){
      var t = card.dataset.type, p = card.dataset.profile;
      var typeOk = activeType==='all' || t===activeType;
      var profOk = activeProfile==='all' || p===activeProfile;
      if(typeOk && profOk){ card.style.display=''; shown++; }
      else { card.style.display='none'; }
    });
    var el = document.getElementById('post-count');
    if(el) el.textContent = 'Showing '+shown+' post'+(shown===1?'':'s');
  }
  document.addEventListener('DOMContentLoaded', function(){
    document.querySelectorAll('.filter-btn').forEach(function(btn){
      btn.addEventListener('click', function(){
        var filter = btn.dataset.filter, val = btn.dataset.val;
        if(filter==='type') activeType = val;
        if(filter==='profile') activeProfile = val;
        document.querySelectorAll('[data-filter="'+filter+'"]').forEach(function(b){
          b.classList.remove('active');
        });
        btn.classList.add('active');
        applyFilters();
      });
    });
  });
})();
</script>
</body>
</html>
